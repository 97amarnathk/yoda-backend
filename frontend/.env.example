# Base URL for the Yoda API. Defaults to "/api" (same-origin) if unset.
# Expected endpoints:
#   GET  {NEXT_PUBLIC_API_URL}/users/:id        -> UserData
#   GET  {NEXT_PUBLIC_API_URL}/users?q=:query   -> UserData[]
#   POST {NEXT_PUBLIC_API_URL}/users            -> UserData   (body: { username: string })
#   GET  {NEXT_PUBLIC_API_URL}/sessions/:id     -> SessionData & { userId: string }
NEXT_PUBLIC_API_URL=http://localhost:4000/api
